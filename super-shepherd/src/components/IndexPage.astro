---
import Layout from '../layouts/Layout.astro';
import MulchCalculator from '../components/MulchCalculator';
import FAQ from '../components/FAQ.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Layers, Maximize2, DollarSign } from 'lucide-react';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
	<Nav lang={lang} />

	<main>
		<!-- Utility Section: Calculator at the top -->
		<section id="calculator" class="relative overflow-hidden pt-12 pb-24 px-6 border-b border-hairline bg-canvas">
			<!-- Background Decor - Subtler for utility focus -->
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-full -z-10 mesh-gradient opacity-30"></div>
			
			<div class="max-w-5xl mx-auto space-y-12">
				<div class="text-center space-y-4">
					<h1 class="display-lg text-ink">{t('calc.title')}</h1>
					<p class="body-md text-body max-w-2xl mx-auto">{t('calc.subtitle')}</p>
				</div>
				
				<div class="classical-card p-1 rounded-sm shadow-level-2 bg-canvas-soft border-hairline-strong">
					<MulchCalculator client:load lang={lang} />
				</div>
			</div>
		</section>

		<!-- Theory & SEO Content Section: Professional Educational Content -->
		<section class="bg-canvas-soft py-24 px-6 border-t border-hairline">
			<div class="max-w-5xl mx-auto space-y-24">
				
				<!-- Main Theory Content -->
				<div class="prose prose-neutral max-w-none 
					prose-headings:font-geist prose-headings:font-semibold prose-headings:tracking-tighter
					prose-h2:text-display-lg prose-h2:mb-12 prose-h2:text-ink
					prose-h3:text-display-sm prose-h3:mt-0 prose-h3:mb-6 prose-h3:text-ink prose-h3:flex prose-h3:items-center prose-h3:gap-3
					prose-h3:before:content-[''] prose-h3:before:w-1 prose-h3:before:h-6 prose-h3:before:bg-primary prose-h3:before:rounded-full
					prose-p:text-body-md prose-p:text-body prose-p:leading-relaxed prose-p:mb-8
					prose-li:text-body-sm prose-li:text-body prose-li:mb-2
					prose-ul:list-disc prose-ul:pl-5 prose-ul:mb-8
					prose-strong:text-ink prose-strong:font-bold
					[&>div>section]:theory-section [&>div>section]:mb-12
				" set:html={t('seo.longContent')}>
				</div>

				<!-- Features Grid - Secondary Info -->
				<div id="features" class="space-y-16">
					<div class="text-center space-y-4">
						<h2 class="display-lg">{t('features.title')}</h2>
						<p class="body-md text-body">{t('features.description')}</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<div class="classical-card p-8 rounded-sm space-y-4">
							<div class="w-10 h-10 bg-cyan-soft rounded-sm border border-cyan-deep/20 flex items-center justify-center">
								<Layers className="w-5 h-5 text-cyan-deep" />
							</div>
							<h3 class="body-md-strong">{t('features.areaTitle')}</h3>
							<p class="body-sm text-body">{t('features.areaText')}</p>
						</div>
						<div class="classical-card p-8 rounded-sm space-y-4">
							<div class="w-10 h-10 bg-violet-soft rounded-sm border border-violet-deep/20 flex items-center justify-center">
								<Maximize2 className="w-5 h-5 text-violet-deep" />
							</div>
							<h3 class="body-md-strong">{t('features.shapesTitle')}</h3>
							<p class="body-sm text-body">{t('features.shapesText')}</p>
						</div>
						<div class="classical-card p-8 rounded-sm space-y-4">
							<div class="w-10 h-10 bg-warning-soft rounded-sm border border-warning-deep/20 flex items-center justify-center">
								<DollarSign className="w-5 h-5 text-warning-deep" />
							</div>
							<h3 class="body-md-strong">{t('features.costTitle')}</h3>
							<p class="body-sm text-body">{t('features.costText')}</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<FAQ lang={lang} />
	</main>

	<Footer lang={lang} />
</Layout>
