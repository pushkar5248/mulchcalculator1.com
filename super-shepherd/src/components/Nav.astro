---
import LanguagePicker from './LanguagePicker.astro';
import ThemeToggle from './ThemeToggle.astro';
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);

const homePath = lang === 'en' ? '/' : `/${lang}/`;
const gravelPath = lang === 'en' ? '/gravel-calculator' : `/${lang}/gravel-calculator`;
---

<nav class="sticky top-0 z-40 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline px-6">
  <div class="h-[64px] flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href={homePath} class="flex items-center gap-2">
        <div class="w-8 h-8 bg-primary rounded-sm flex items-center justify-center">
          <span class="text-on-primary font-bold text-xl leading-none">M</span>
        </div>
        <span class="body-md-strong tracking-tighter">mulchcalculator1.com</span>
      </a>
      <div class="hidden md:flex items-center gap-6">
        <a href={`${homePath}#calculator`} class="body-sm text-body hover:text-ink transition-colors">Mulch Calculator</a>
        <a href={gravelPath} class="body-sm text-body hover:text-ink transition-colors">Gravel Calculator</a>
        <a href={`${homePath}#faq`} class="body-sm text-body hover:text-ink transition-colors">{t('nav.faq')}</a>
        <a href={`${homePath}about-us`} class="body-sm text-body hover:text-ink transition-colors">{t('nav.about')}</a>
      </div>
    </div>
    <div class="flex items-center gap-2 md:gap-4">
      <LanguagePicker />
      <ThemeToggle />
      <button 
        id="mobile-menu-button"
        class="md:hidden w-10 h-10 flex items-center justify-center rounded-sm hover:bg-canvas-soft border border-hairline transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu block dark:text-ink"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x hidden dark:text-ink"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div 
    id="mobile-menu"
    class="hidden border-t border-hairline py-4 space-y-4 bg-canvas animate-in slide-in-from-top duration-200"
  >
    <a href={`${homePath}#calculator`} class="block body-md text-body hover:text-ink transition-colors px-2">Mulch Calculator</a>
    <a href={gravelPath} class="block body-md text-body hover:text-ink transition-colors px-2">Gravel Calculator</a>
    <a href={`${homePath}#faq`} class="block body-md text-body hover:text-ink transition-colors px-2">{t('nav.faq')}</a>
    <a href={`${homePath}about-us`} class="block body-md text-body hover:text-ink transition-colors px-2">{t('nav.about')}</a>
    <a href={`${homePath}contact-us`} class="block body-md text-body hover:text-ink transition-colors px-2">{t('nav.contact')}</a>
  </div>
</nav>

<script is:inline>
  function setupMobileMenu() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const icons = button?.querySelectorAll('svg');

    if (!button || !menu || !icons) return;

    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', !isExpanded);
      menu.classList.toggle('hidden');
      icons[0].classList.toggle('hidden');
      icons[1].classList.toggle('hidden');
    });

    // Close menu when clicking a link
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        button.setAttribute('aria-expanded', 'false');
        menu.classList.add('hidden');
        icons[0].classList.remove('hidden');
        icons[1].classList.add('hidden');
      });
    });
  }

  // Initial setup
  setupMobileMenu();
  // Setup on View Transitions
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
