---
import ProseLayout from '../../layouts/ProseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<ProseLayout title={t('contact.title')}>
  <div set:html={t('contact.content')} />
  
  <form class="space-y-6 mt-12 bg-canvas-soft p-8 rounded-xl border border-hairline">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <label class="caption-mono text-ink" for="name">Name</label>
        <input class="w-full px-4 py-3 bg-canvas border border-hairline rounded-sm focus:outline-none focus:border-primary transition-colors" type="text" id="name" placeholder="Your name" />
      </div>
      <div class="space-y-2">
        <label class="caption-mono text-ink" for="email">Email</label>
        <input class="w-full px-4 py-3 bg-canvas border border-hairline rounded-sm focus:outline-none focus:border-primary transition-colors" type="email" id="email" placeholder="your@email.com" />
      </div>
    </div>
    <div class="space-y-2">
      <label class="caption-mono text-ink" for="message">Message</label>
      <textarea class="w-full px-4 py-3 bg-canvas border border-hairline rounded-sm focus:outline-none focus:border-primary transition-colors min-h-[150px]" id="message" placeholder="How can we help?"></textarea>
    </div>
    <button class="bg-primary text-on-primary px-8 py-4 rounded-sm body-md-strong hover:bg-primary/90 transition-all shadow-level-1 hover:shadow-level-2 active:scale-[0.98]" type="submit">
      Send Message
    </button>
  </form>
</ProseLayout>

