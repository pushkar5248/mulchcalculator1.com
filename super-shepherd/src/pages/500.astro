---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homePath = lang === 'en' ? '/' : `/${lang}/`;
---

<Layout title={t('error.500.title')}>
  <Nav lang={lang} />
  
  <main class="min-h-[70vh] flex items-center justify-center px-6 relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-4xl h-full -z-10 mesh-gradient opacity-30"></div>

    <div class="max-w-md w-full text-center space-y-8 animate-in fade-in slide-in-from-bottom-8 duration-700">
      <div class="space-y-6">
        <div class="inline-flex w-20 h-20 bg-canvas-soft border border-hairline rounded-2xl items-center justify-center shadow-level-1 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/><polyline points="12 12 12 12"/></svg>
        </div>
        
        <div class="space-y-2">
          <h1 class="display-xl text-primary leading-none">500</h1>
          <h2 class="display-md text-ink">{t('error.500.title')}</h2>
          <p class="body-md text-body">
            {t('error.500.description')}
          </p>
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <a 
          href={homePath}
          class="w-full sm:w-auto inline-flex h-12 px-8 bg-primary text-on-primary rounded-pill body-sm-strong items-center justify-center hover:shadow-level-3 hover:-translate-y-0.5 transition-all"
        >
          {t('error.500.cta')}
        </a>
        <button 
          onclick="window.location.reload()"
          class="w-full sm:w-auto inline-flex h-12 px-8 bg-canvas-soft text-ink border border-hairline rounded-pill body-sm-strong items-center justify-center hover:bg-canvas transition-all"
        >
          Try Again
        </button>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
